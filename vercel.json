{
  "installCommand": "npm install",
  "buildCommand": "cd apps/frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/backend/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
