{
  "installCommand": "npm install && npm install --platform=linux --arch=x64 sharp",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "nodeVersion": "20.x",
  "rewrites": [
    { "source": "/api/api/:path*", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
